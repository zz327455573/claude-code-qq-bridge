# ==========================================
# Claude Code QQ Bridge v2.0 配置文件模板
# 复制本文件为 .env，填入真实凭据
# ==========================================

# QQ Bot 官方平台 AppID 与 ClientSecret
APP_ID=YOUR_QQ_BOT_APP_ID
CLIENT_SECRET=YOUR_QQ_BOT_CLIENT_SECRET

# Master 用户的 OpenID（非 Master 消息将被自动忽略）
MASTER_OPENID=YOUR_MASTER_OPENID
